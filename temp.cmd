opparm attribwrangle4 folder0 ( 0 0 ) group ( "" ) grouptype ( guess ) class ( primitive ) vex_numcount ( 10 ) vex_threadjobsize ( 1024 ) snippet ( '// --- 設定 ---\nfloat target_dist = chf("target_distance"); // 切りたい距離（例: 5.0m）\n\n// 1. カーブの全長を取得\nfloat total_len = primarclen(0, {0,0}, {1,0}, @primnum);\nfloat ratio = clamp(target_dist / total_len, 0.0, 1.0);\n//printf("total_len: %f\\n", total_len);\n\n// 2. 指定した「長さの割合」における座標(P)を取得\n// \'len\' を指定すると、実際の弧長（Arc Length）に基づいた位置を返してくれる\nvector pos = primuv(0, "P", @primnum, ratio); \n// ※H21ではprimuvの第4引数を \'len\' モードで扱う仕組みがありますが、\n// 最も確実なのは、あらかじめResample SOPで「等間隔」にしておくことです。\n\n//printf("ratio: %f, pos: %f\\n", ratio, pos);\n// 3. 座標から、パラメータとしての正確なU値を逆引き\nint hit_prim;\nvector hit_uv;\nxyzdist(0, pos, hit_prim, hit_uv);\nfloat u_value = hit_uv.x; // これが分割に使える0-1のパラメータ\n//printf("hit_uv: %f\\n", hit_uv);\n\n// 4. そのUV値がどのポイント間（セグメント）にあるか特定\nint segment_idx = int(floor(u_value * (len(primpoints(0, @primnum)) - 1)));\n//printf("%f\\n", segment_idx);\n\n// 5. 新しいポイントを作成\nint new_pt = addpoint(0, pos);\n\n// 6. 既存のポイント配列を取得して分割\nint old_pts[] = primpoints(0, @primnum);\n\nint first_half[] = old_pts[:segment_idx + 1];\nappend(first_half, new_pt);\n\nint second_half[];\nappend(second_half, new_pt);\nint tail[] = old_pts[segment_idx + 1:];\nappend(second_half, tail);\n\n// 7. 新しいプリミティブを作成\nint prim1 = addprim(0, "polyline");\nint prim2 = addprim(0, "polyline");\n\nforeach (int p; first_half) addvertex(0, prim1, p);\nforeach (int p; second_half) addvertex(0, prim2, p);\n\n// 8. 元のプリミティブを削除\nremoveprim(0, @primnum, 1);' ) exportlist ( * ) vex_strict ( off ) vex_strictvariables ( on ) autobind ( on ) bindings ( 0 ) groupautobind ( on ) groupbindings ( 0 ) vex_cwdpath ( . ) vex_outputmask ( * ) vex_updatenmls ( off ) vex_matchattrib ( id ) vex_inplace ( off ) vex_selectiongroup ( "" ) vex_precision ( auto ) folder1 ( 0 0 ) folder_generatedparms_snippet ( 0 ) target_distance ( 0.21 )
