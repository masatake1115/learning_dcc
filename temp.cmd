  //pB += pB2C;\n    pBExtend = length(pB2C);\n}\n\nfloat l_limit = 1.0e+9;\n{\n    float len_pA2C = sign(dot(nA, pA2C)) * length(pA2C);\n    float len_pB2C = sign(dot(-nB, pB2C)) * length(pB2C);\n    //printf("len_pA2C=%f, len_pB2C=%f\\n", len_pA2C, len_pB2C);\n    l_limit = max(min(len_pA2C, len_pB2C), 0.0);\n}\n\n\n// 3. Compute l(distance between pA/pB and arc terminal)\nfloat angle = acos(clamp(dot(nA, -nB), -1, 1));\nfloat l = min( 0.5*dist / sin(0.5*angle), l_limit );\nfloat r = l * tan(0.5*angle);// circle radius\n\nvector pStart = C - nA * l;\nvector pEnd = C + nB * l;\n\n// 4. Compute arc center\nvector side = normalize(cross(nA, nB));\nvector startV = normalize(cross(side, nA)); // vector from pStart to center\nvector center = pStart + startV * r;\n\n// 5. Create\nint prim = addprim(0, "polyline");\n\n// Section1: A to arc-start\nint id_pA = addpoint(0, pA);\naddvertex(0, prim, id_pA);\naddvertex(0, prim, addpoint(0, pStart));\n\n// Section2: Arc\nvector endV = normalize(pEnd - center);\nfloat total_arc_angle = acos(clamp(dot(normalize(pStart - center), endV), -1, 1));\n\nfor(int i=1; i<res; ++i)\n{\n    float t = float(i)/res;\n    // Generate arc sample point using quaternion\n    vector p_arc = center + qrotate(quaternion(total_arc_angle * t, side), pStart - center);\n    addvertex(0, prim, addpoint(0, p_arc));\n}\n\n// Section3: Arc-end to B\naddvertex(0, prim, addpoint(0, pEnd));\nint id_pB = addpoint(0, pB);\naddvertex(0, prim, id_pB);\n\n\n\naddpointattrib(0, "branch_idx", -1);\n\nint branch_idx = point(1, "branch_idx", 0);\nsetpointattrib(0, "branch_idx", id_pA, branch_idx);\n\nbranch_idx = point(1, "branch_idx", 1);\nsetpointattrib(0, "branch_idx", id_pB, branch_idx);\n\naddpointattrib(0, "extend", 0.0);\n\n\n\naddpointattrib(0, "corner", -1);\n\nint corner_id = point(1, "corner", 0);\nsetpointattrib(0, "corner_type", id_pA, "right");\nsetpointattrib(0, "corner", id_pA, corner_id);\nsetpointattrib(0, "extend", id_pA, pAExtend);\n\ncorner_id = poi