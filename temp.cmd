pB += pB2C;\n    pBExtend = length(pB2C);\n}\n\n\n// 3. Compute l(distance between pA/pB and arc terminal)\nfloat angle = acos(clamp(dot(nA, -nB), -1, 1));\nfloat l = 0.5*dist / sin(0.5*angle);\nfloat r = l * tan(0.5*angle);// circle radius\n\nvector pStart = C - nA * l;\nvector pEnd = C + nB * l;\n\n// 4. Compute arc center\nvector side = normalize(cross(nA, nB));\nvector startV = normalize(cross(side, nA)); // vector from pStart to center\nvector center = pStart + startV * r;\n\n// 5. Create\nint prim = addprim(0, "polyline");\n\n// Section1: A to arc-start\nint id_pA = addpoint(0, pA);\naddvertex(0, prim, id_pA);\naddvertex(0, prim, addpoint(0, pStart));\n\n// Section2: Arc\nvector endV = normalize(pEnd - center);\nfloat total_arc_angle = acos(clamp(dot(normalize(pStart - center), endV), -1, 1));\n\nfor(int i=1; i<res; ++i)\n{\n    float t = float(i)/res;\n    // Generate arc sample point using quaternion\n    vector p_arc = center + qrotate(quaternion(total_arc_angle * t, side), pStart - center);\n    addvertex(0, prim, addpoint(0, p_arc));\n}\n\n// Section3: Arc-end to B\n//addvertex(0, prim, addpoint(0, pEnd));\nint id_pB = addpoint(0, pB);\naddvertex(0, prim, id_pB);\n\n\n\n\n\n/*\nfloat lenA = point(1, "length", 0);\nfloat lenB = point(1, "length", 1);\n\naddpointattrib(0, "corner", -1);\naddpointattrib(0, "length", 0.0);\n\nint corner_id = point(1, "corner", 0);\nsetpointattrib(0, "corner_type", id_pA, "right");\nsetpointattrib(0, "corner", id_pA, corner_id);\nsetpointattrib(0, "extend", id_pA, pAExtend);\n\n\ncorner_id = point(1, "corner", 1);\nsetpointattrib(0, "corner_type", id_pB, "left");\nsetpointattrib(0, "corner", id_pB, corner_id);\nsetpointattrib(0, "extend", id_pB, pBExtend);\n*/' ) exportlist ( * ) vex_strict ( off ) vex_strictvariables ( on ) autobind ( on ) bindings ( 0 ) groupautobind ( on ) groupbindings ( 0 ) vex_cwdpath ( . ) vex_outputmask ( * ) vex_updatenmls ( off ) vex_matchattrib ( id ) vex_inplace ( off ) vex_selectiongroup ( "" ) ve